<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- VS Code Dark+ / Warp reng palitasi -->
    <Color x:Key="BG_Base">#1E1E2E</Color>
    <Color x:Key="BG_Surface">#181825</Color>
    <Color x:Key="BG_Overlay">#24273A</Color>
    <Color x:Key="BG_Sidebar">#12121F</Color>
    <Color x:Key="BG_Input">#2A2A3D</Color>
    <Color x:Key="BG_Hover">#313244</Color>
    <Color x:Key="BG_Active">#45475A</Color>
    <Color x:Key="BG_Selection">#363659</Color>

    <Color x:Key="Accent_Blue">#89B4FA</Color>
    <Color x:Key="Accent_Green">#A6E3A1</Color>
    <Color x:Key="Accent_Red">#F38BA8</Color>
    <Color x:Key="Accent_Yellow">#F9E2AF</Color>
    <Color x:Key="Accent_Purple">#CBA6F7</Color>
    <Color x:Key="Accent_Cyan">#89DCEB</Color>
    <Color x:Key="Accent_Orange">#FAB387</Color>

    <Color x:Key="Text_Primary">#CDD6F4</Color>
    <Color x:Key="Text_Secondary">#A6ADC8</Color>
    <Color x:Key="Text_Muted">#585B70</Color>
    <Color x:Key="Border_Default">#313244</Color>

    <!-- Solidbrushlar -->
    <SolidColorBrush x:Key="Brush.BG.Base" Color="{StaticResource BG_Base}"/>
    <SolidColorBrush x:Key="Brush.BG.Surface" Color="{StaticResource BG_Surface}"/>
    <SolidColorBrush x:Key="Brush.BG.Overlay" Color="{StaticResource BG_Overlay}"/>
    <SolidColorBrush x:Key="Brush.BG.Sidebar" Color="{StaticResource BG_Sidebar}"/>
    <SolidColorBrush x:Key="Brush.BG.Input" Color="{StaticResource BG_Input}"/>
    <SolidColorBrush x:Key="Brush.BG.Hover" Color="{StaticResource BG_Hover}"/>
    <SolidColorBrush x:Key="Brush.BG.Active" Color="{StaticResource BG_Active}"/>
    <SolidColorBrush x:Key="Brush.BG.Selection" Color="{StaticResource BG_Selection}"/>

    <SolidColorBrush x:Key="Brush.Accent.Blue" Color="{StaticResource Accent_Blue}"/>
    <SolidColorBrush x:Key="Brush.Accent.Green" Color="{StaticResource Accent_Green}"/>
    <SolidColorBrush x:Key="Brush.Accent.Red" Color="{StaticResource Accent_Red}"/>
    <SolidColorBrush x:Key="Brush.Accent.Purple" Color="{StaticResource Accent_Purple}"/>
    <SolidColorBrush x:Key="Brush.Accent.Cyan" Color="{StaticResource Accent_Cyan}"/>
    <SolidColorBrush x:Key="Brush.Accent.Orange" Color="{StaticResource Accent_Orange}"/>

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Text_Primary}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Text_Secondary}"/>
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{StaticResource Text_Muted}"/>
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Border_Default}"/>

    <!-- Fontlar -->
    <FontFamily x:Key="Font.Code">Cascadia Code, Consolas, Courier New</FontFamily>
    <FontFamily x:Key="Font.UI">Segoe UI Variable, Segoe UI, Arial</FontFamily>

</ResourceDictionary>
