<Window x:Class="WA.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Windows AI" Height="920" Width="1440"
        MinHeight="600" MinWidth="860"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResize"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <Window.Resources>
        <Style x:Key="TitleBtn" TargetType="Button" BasedOn="{StaticResource Btn.Ghost}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="ModeBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" CornerRadius="3" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.Accent.Blue}"/>
                                <Setter Property="Foreground" Value="#1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.BG.Overlay}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="{StaticResource Brush.BG.Base}"
            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="22"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Background="{StaticResource Brush.BG.Surface}"
                    CornerRadius="10,10,0,0" PreviewMouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="26" Height="26" CornerRadius="6"
                            Background="#2B3A5C" HorizontalAlignment="Center">
                        <TextBlock Text="AI" Foreground="{StaticResource Brush.Accent.Blue}"
                                   FontWeight="Bold" FontSize="10"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Session tabs + status -->
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status (chap) -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,10,0">
                            <Border x:Name="StatusDot" Width="7" Height="7" CornerRadius="4"
                                    Background="{StaticResource Brush.Accent.Orange}"
                                    VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusText" Text="Yuklanmoqda..."
                                       Foreground="{StaticResource Brush.Text.Muted}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Sessiya tablari (o'ng, VS Code uslubi) -->
                        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" VerticalAlignment="Stretch">
                            <StackPanel x:Name="SessionTabs" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Yangi sessiya tab qo'shish -->
                        <Button Style="{StaticResource Btn.Ghost}" Content="＋"
                                Width="32" Height="28" FontSize="14" Margin="0,0,6,0"
                                ToolTip="Yangi sessiya"
                                Click="NewSession_Click"/>
                        <Button Style="{StaticResource TitleBtn}" Content="─" Click="Minimize_Click"/>
                        <Button Style="{StaticResource TitleBtn}" Content="□" Click="Maximize_Click"/>
                        <Button Style="{StaticResource TitleBtn}" Content="✕" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Activity bar -->
                    <ColumnDefinition Width="46"/>
                    <!-- File tree -->
                    <ColumnDefinition Width="220" MinWidth="120" x:Name="SidebarCol"/>
                    <!-- Splitter -->
                    <ColumnDefinition Width="4"/>
                    <!-- AI Chat (asosiy, chap) -->
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <!-- Editor splitter (yashirin) -->
                    <ColumnDefinition Width="0" x:Name="EditorSplitterCol"/>
                    <!-- Kod editor (o'ng, yashirin → fayl bosganda ochiladi) -->
                    <ColumnDefinition Width="0" x:Name="EditorCol"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ ACTIVITY BAR ═══ -->
                <Border Grid.Column="0" Background="{StaticResource Brush.BG.Sidebar}">
                    <Grid>
                        <StackPanel VerticalAlignment="Top" Margin="0,6">
                            <Button x:Name="ActFilesBtn" Style="{StaticResource Btn.Ghost}"
                                    Width="36" Height="36" Margin="5,2"
                                    ToolTip="Fayl daraxti" Click="ActFiles_Click">
                                <TextBlock Text="📁" FontSize="15"/>
                            </Button>
                            <Button Style="{StaticResource Btn.Ghost}"
                                    Width="36" Height="36" Margin="5,2"
                                    ToolTip="Suhbat tarixi" Click="ActHistory_Click">
                                <TextBlock Text="💬" FontSize="15"/>
                            </Button>
                        </StackPanel>
                        <Button VerticalAlignment="Bottom" Style="{StaticResource Btn.Ghost}"
                                Width="36" Height="36" Margin="5,8"
                                ToolTip="Sozlamalar" Click="Settings_Click">
                            <TextBlock Text="⚙" FontSize="15"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ═══ FILE TREE ═══ -->
                <Border Grid.Column="1" Background="{StaticResource Brush.BG.Sidebar}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="10,0,4,0">
                            <TextBlock Text="FAYL DARAXTI" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text.Muted}"
                                       VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Style="{StaticResource Btn.Ghost}"
                                    Width="26" Height="26" Content="📂" FontSize="13"
                                    ToolTip="Papka ochish" Click="OpenFolder_Click"/>
                        </Grid>
                        <TreeView x:Name="FileTree" Grid.Row="1"
                                  Background="Transparent" BorderThickness="0"
                                  Foreground="{StaticResource Brush.Text.Secondary}"
                                  FontFamily="{StaticResource Font.UI}" FontSize="12"
                                  AllowDrop="True" Drop="FileTree_Drop"
                                  MouseDoubleClick="FileTree_DoubleClick"
                                  SelectedItemChanged="FileTree_SelectedItemChanged"/>
                    </Grid>
                </Border>

                <!-- Sidebar/AI splitter -->
                <GridSplitter Grid.Column="2" Width="4" HorizontalAlignment="Stretch"
                              Background="Transparent" Cursor="SizeWE"/>

                <!-- ═══ AI CHAT (asosiy panel) ═══ -->
                <Grid Grid.Column="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>      <!-- AI header -->
                        <RowDefinition Height="*"/>       <!-- messages -->
                        <RowDefinition Height="Auto"/>    <!-- activity bar -->
                        <RowDefinition Height="Auto"/>    <!-- command bar -->
                    </Grid.RowDefinitions>

                    <!-- AI Header -->
                    <Border Background="{StaticResource Brush.BG.Overlay}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1">
                        <Grid Margin="10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="AiDot" Width="6" Height="6" CornerRadius="3"
                                        Background="{StaticResource Brush.Accent.Green}"
                                        Margin="0,0,7,0"/>
                                <TextBlock x:Name="AiPanelStatus" Text="AI Agent"
                                           Foreground="{StaticResource Brush.Text.Muted}"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="ModelCombo" Margin="12,0,0,0"
                                          Background="Transparent"
                                          Foreground="{StaticResource Brush.Text.Secondary}"
                                          BorderBrush="Transparent"
                                          FontSize="11" Height="24" MinWidth="140"
                                          SelectionChanged="ModelCombo_Changed"/>

                                <!-- API Key Popup (DeepSeek / OpenAI tanlanganda) -->
                                <Popup x:Name="ApiKeyPopup"
                                       PlacementTarget="{Binding ElementName=ModelCombo}"
                                       Placement="Bottom" StaysOpen="True"
                                       AllowsTransparency="True">
                                    <Border Background="#1e1e2e"
                                            BorderBrush="#45475a" BorderThickness="1"
                                            CornerRadius="8" Padding="14,12,14,12"
                                            MinWidth="310">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18" ShadowDepth="2"
                                                              Opacity="0.75" Color="#000000"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <!-- Header row -->
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock x:Name="ApiKeyProviderLabel"
                                                           Text="🔑 DeepSeek API Kaliti"
                                                           Foreground="#fab387" FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <Button HorizontalAlignment="Right"
                                                        Content="✕" Width="22" Height="22"
                                                        FontSize="9" Padding="0"
                                                        Background="Transparent"
                                                        Foreground="#6c7086"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Click="CloseApiKey_Click"/>
                                            </Grid>
                                            <!-- Key input -->
                                            <PasswordBox x:Name="ApiKeyInput"
                                                         Height="32" FontSize="12"
                                                         Background="#181825"
                                                         Foreground="#cdd6f4"
                                                         BorderBrush="#45475a"
                                                         BorderThickness="1"
                                                         Padding="8,0"
                                                         PasswordChar="●"
                                                         KeyDown="ApiKeyInput_KeyDown"/>
                                            <!-- Footer row -->
                                            <Grid Margin="0,8,0,0">
                                                <TextBlock Text="Enter — saqlash  |  Esc — yopish"
                                                           Foreground="#6c7086" FontSize="10"
                                                           VerticalAlignment="Center"/>
                                                <Button HorizontalAlignment="Right"
                                                        Content="Saqlash"
                                                        Height="28" Padding="12,0"
                                                        FontSize="11"
                                                        Background="#3a5cad"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Click="SaveApiKey_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Style="{StaticResource Btn.Ghost}" Content="＋"
                                        Width="24" Height="24" ToolTip="Yangi suhbat"
                                        Click="NewChat_Click"/>
                                <Button Style="{StaticResource Btn.Ghost}" Content="🗑"
                                        Width="24" Height="24" ToolTip="Tozalash"
                                        Click="ClearChat_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Messages (real-time streaming) -->
                    <ScrollViewer Grid.Row="1" x:Name="ChatScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalFirst">
                        <StackPanel x:Name="MessagesPanel" Margin="0,4,0,8"/>
                    </ScrollViewer>

                    <!-- Activity Bar ("Puttering...") — auto-visible when AI is working -->
                    <Border Grid.Row="2" x:Name="ActivityBar"
                            Background="#111120"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0"
                            Padding="14,5" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Pulsing dot -->
                            <Border x:Name="ActivityDot" Width="7" Height="7" CornerRadius="4"
                                    Background="{StaticResource Brush.Accent.Green}"
                                    Margin="0,0,9,0" Opacity="1">
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="1" To="0.15"
                                                    Duration="0:0:0.75"
                                                    AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                            <TextBlock x:Name="ActivityText" Text="Ishlayapti..."
                                       Foreground="{StaticResource Brush.Text.Muted}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Command Bar -->
                    <Border Grid.Row="3" Background="{StaticResource Brush.BG.Input}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0"
                            Padding="12,8,12,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- context chip -->
                                <RowDefinition Height="Auto"/>  <!-- chat input -->
                                <RowDefinition Height="Auto"/>  <!-- buttons -->
                            </Grid.RowDefinitions>

                            <!-- Context chip: selected file/folder from tree -->
                            <Border x:Name="ContextChip" Grid.Row="0"
                                    Visibility="Collapsed"
                                    Background="#1e2040" CornerRadius="4"
                                    Padding="8,4" Margin="0,0,0,6">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="📎 " FontSize="11"
                                                   Foreground="#89b4fa" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ContextChipLabel"
                                                   FontSize="11" Foreground="#89b4fa"
                                                   VerticalAlignment="Center"
                                                   MaxWidth="200"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- Taxlil button (papka tanlanganda) -->
                                        <Button x:Name="AnalyzeBtn"
                                                Content="📊 Taxlil" Height="22" Padding="8,0"
                                                FontSize="10" Margin="8,0,0,0"
                                                Background="#2a3060" Foreground="#89b4fa"
                                                BorderThickness="0" Cursor="Hand"
                                                Visibility="Collapsed"
                                                Click="AnalyzeProject_Click"/>
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right" Content="✕"
                                            Width="18" Height="18" FontSize="8" Padding="0"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#6c7086" Cursor="Hand"
                                            Click="ClearContext_Click"/>
                                </Grid>
                            </Border>

                            <!-- Chat Input -->
                            <TextBox x:Name="ChatInput" Grid.Row="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource Brush.Text.Primary}"
                                     FontFamily="{StaticResource Font.UI}" FontSize="14"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="28" MaxHeight="160"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="0,4" KeyDown="ChatInput_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource Input.Dark}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Grid Grid.Row="2" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource Btn.Ghost}" Content="📎"
                                            Width="34" Height="32" FontSize="14"
                                            ToolTip="Fayl biriktirish" Click="AttachFile_Click"/>
                                    <Button x:Name="VoiceBtn" Style="{StaticResource Btn.Ghost}"
                                            Content="🎤" Width="34" Height="32" FontSize="14"
                                            ToolTip="Ovozli buyruq" Click="Voice_Click"/>
                                    <TextBlock Text="Ctrl+↵ = yuborish" FontSize="11"
                                               Foreground="{StaticResource Brush.Text.Muted}"
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{StaticResource Brush.BG.Surface}"
                                            CornerRadius="5" Margin="0,0,10,0" Padding="3">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton x:Name="ModeAsk"
                                                         Style="{StaticResource ModeBtn}"
                                                         Content="Ask" GroupName="EditMode"
                                                         IsChecked="True"
                                                         Checked="Mode_Changed"/>
                                            <RadioButton x:Name="ModeAuto"
                                                         Style="{StaticResource ModeBtn}"
                                                         Content="Auto" GroupName="EditMode"
                                                         Checked="Mode_Changed"/>
                                        </StackPanel>
                                    </Border>
                                    <Button x:Name="StopBtn"
                                            Style="{StaticResource Btn.Ghost}"
                                            Content="⬛  Stop" Height="34" Padding="12,0"
                                            FontSize="13"
                                            Visibility="Collapsed"
                                            Foreground="{StaticResource Brush.Accent.Red}"
                                            BorderBrush="{StaticResource Brush.Accent.Red}"
                                            BorderThickness="1" Margin="0,0,8,0"
                                            Click="Cancel_Click"/>
                                    <Button x:Name="SendBtn"
                                            Style="{StaticResource Btn.Primary}"
                                            Content="▶  Yuborish" Height="34" Padding="18,0"
                                            FontSize="13"
                                            Click="Send_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Editor splitter (fayl ochilganda ko'rinadi) -->
                <GridSplitter Grid.Column="4" Width="4" HorizontalAlignment="Stretch"
                              Background="{StaticResource Brush.Border}" Cursor="SizeWE"
                              x:Name="EditorSplitter" Visibility="Collapsed"/>

                <!-- ═══ KOD EDITOR (o'ng, yashirin) ═══ -->
                <Grid Grid.Column="5" x:Name="EditorPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab bar -->
                    <Border Background="{StaticResource Brush.BG.Surface}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1,0,0,1">
                        <Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Hidden">
                                <StackPanel x:Name="EditorTabs" Orientation="Horizontal"/>
                            </ScrollViewer>
                            <TextBlock x:Name="EditorHint" Text="Fayl tanlang"
                                       Foreground="{StaticResource Brush.Text.Muted}"
                                       FontSize="11" VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Monaco Editor -->
                    <wv2:WebView2 x:Name="MonacoEditor" Grid.Row="1"/>
                </Grid>
            </Grid>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Background="{StaticResource Brush.Accent.Blue}"
                    CornerRadius="0,0,10,10">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ProviderText" Text="ollama / qwen2.5:7b"
                                   Foreground="#1E1E2E" FontSize="11" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="MemUsage" Foreground="#1E1E2E" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
